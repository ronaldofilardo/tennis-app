# Template de variáveis de ambiente — copie para .env.development / .env.test / .env.production
# NUNCA commitar arquivos .env com credenciais reais.

# === Banco de dados ===
# Desenvolvimento local (PostgreSQL):
# DATABASE_URL="postgresql://<usuario>:<senha>@localhost:5432/<banco>?schema=public&sslmode=disable"
# Produção (Neon):
# DATABASE_URL="postgresql://<usuario>:<senha>@<host>.neon.tech/<banco>?sslmode=require"
DATABASE_URL=""

# === Autenticação ===
# OBRIGATÓRIO em produção — mínimo 32 caracteres, gerado com: openssl rand -hex 32
JWT_SECRET=""

# === API ===
NODE_ENV=development
VITE_API_URL=

# === Pagamentos (opcional) ===
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=

# === CORS (opcional — deixar vazio em dev usa "*") ===
ALLOWED_ORIGIN=
