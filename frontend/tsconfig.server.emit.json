{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.emit.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": false,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/services/authService.ts",
    "src/services/businessLogic.ts",
    "src/services/tenantMiddleware.ts",
    "src/schemas/contracts.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.js"]
}
