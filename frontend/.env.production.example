# .env.production.example
# Configurações necessárias para produção
# Copie para .env.production e preencha com valores reais
# NUNCA commitar .env.production no repositório

# CORS e domínio
ALLOWED_ORIGIN=https://racketapp.vercel.app

# JWT Secret (gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=seu_jwt_secret_super_seguro_aqui_64_caracteres_minimo

# Database URL (Neon, Railway, etc)
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public&sslmode=require

# Node environment
NODE_ENV=production

# API Configuration
VITE_API_URL=https://racketapp.vercel.app/api
