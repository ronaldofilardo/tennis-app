// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS — Fonte única de verdade para roles, status e tipos
// ============================================================

/// Tipo de plataforma do usuário — independente de clube.
/// MEMBER = usuário vinculado a pelo menos um clube.
enum PlatformRole {
  ADMIN
  SCORER
  INDEPENDENT_ATHLETE
  SPECTATOR
  MEMBER
}

enum UserRole {
  ADMIN
  GESTOR
  COACH
  ATHLETE
  SPECTATOR
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum MatchStatus {
  NOT_STARTED
  IN_PROGRESS
  FINISHED
}

enum MatchVisibility {
  PUBLIC
  CLUB
  PLAYERS_ONLY
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  GROUP_STAGE
}

enum TournamentEntryStatus {
  REGISTERED
  CONFIRMED
  WITHDRAWN
  ELIMINATED
  CHAMPION
}

enum OrganizerRole {
  ORGANIZER
  HEAD_REFEREE
}

enum PlanType {
  FREE
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum InvoiceStatus {
  PENDING
  CONFIRMED
  OVERDUE
  REFUNDED
}

enum AnnotationSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum DashboardShareStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DashboardShareType {
  ANNOTATION
  COMPARISON
}

// ============================================================
// FASE 1: Identidade e Multi-tenancy
// ============================================================

/// Clube (Tenant principal). Cada clube isola seus dados.
model Club {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // ex: "clube-harmonia"
  planType    PlanType @default(FREE)

  inviteCode        String? @unique // Código de convite único (6 chars)
  defaultVisibility String  @default("CLUB") // Visibilidade padrão de partidas
  defaultScoreMode  String  @default("technical") // Modo padrão: "family" ou "technical"
  billingModel      String  @default("B2B") // "B2B" = clube paga, "B2C" = atleta paga

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  ClubMembership[]
  matches      Match[]
  homeMatches  Match[]          @relation("MatchHomeClub")
  awayMatches  Match[]          @relation("MatchAwayClub")
  tournaments  Tournament[]
  subscription Subscription?
  invoices     Invoice[]

  @@map("clubs")
}

// ============================================================
// Subscription & Billing (SaaS)
// ============================================================

/// Assinatura do clube — controla acesso à plataforma.
model Subscription {
  id                  String             @id @default(cuid())
  clubId              String             @unique
  planType            PlanType           @default(FREE)
  status              SubscriptionStatus @default(ACTIVE)
  billingCycle        BillingCycle       @default(MONTHLY)
  maxAthletes         Int                @default(10) // FREE=10, PREMIUM=50, ENTERPRISE=999999
  currentPeriodStart  DateTime           @default(now())
  currentPeriodEnd    DateTime
  // Integração Asaas (preparado para futura integração)
  asaasCustomerId     String?
  asaasSubscriptionId String?
  canceledAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  club     Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([status])
  @@map("subscriptions")
}

/// Faturas geradas por assinatura.
model Invoice {
  id                 String        @id @default(cuid())
  subscriptionId     String
  clubId             String
  asaasPaymentId     String?       @unique // ID de pagamento no Asaas
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("BRL")
  status             InvoiceStatus @default(PENDING)
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  paidAt             DateTime?
  invoiceUrl         String? // URL para download de boleto/NF
  createdAt          DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  club         Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([subscriptionId])
  @@map("invoices")
}

/// Usuário autenticado (identidade global). Um User pode pertencer a N clubes.
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  avatarUrl    String?
  isActive     Boolean      @default(true)
  platformRole PlatformRole @default(MEMBER) // Tipo independente de clube
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships    ClubMembership[]
  athleteProfile AthleteProfile?
  createdMatches Match[]               @relation("MatchCreator")
  createdVenues  Venue[]               @relation("VenueCreator")
  tournaments    TournamentOrganizer[]
  annotationSessions MatchAnnotationSession[] @relation("AnnotationSessions")
  endorsements       AnnotationEndorsement[]  @relation("Endorsements")

  @@map("users")
}

/// Vínculo User ↔ Club com role específica dentro do clube.
model ClubMembership {
  id     String   @id @default(cuid())
  userId String
  clubId String
  role   UserRole @default(ATHLETE)

  invitedByUserId String? // User que convidou este membro
  status          MembershipStatus @default(ACTIVE)

  // === LGPD / Compliance ===
  guardianEmail         String? // Email do responsável (menores de 18)
  guardianConsentAt     DateTime? // Data do consentimento do responsável
  dataExportRequestedAt DateTime? // Data da solicitação de exportação LGPD
  deletionRequestedAt   DateTime? // Data da solicitação de exclusão LGPD

  // === Billing B2C (atleta paga) ===
  asaasPaymentId String? @unique // ID de pagamento individual no Asaas

  // === Acúmulo de funções ===
  alsoCoach Boolean @default(false) // Gestor que também exerce função de técnico

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, clubId])
  @@index([clubId])
  @@map("club_memberships")
}

// ============================================================
// FASE 2: Base Central de Atletas
// ============================================================

/// Perfil público de atleta. Dados completos visíveis apenas para o clube "dono".
/// Outros clubes veem somente nome + clube de origem.
/// globalId é o identificador global único do atleta na plataforma (diretório central).
model AthleteProfile {
  id        String    @id @default(cuid())
  globalId  String    @unique @default(cuid()) // ID global imutável — identidade no diretório central
  userId    String?   @unique // null = atleta convidado / sem conta
  name      String
  nickname  String?
  birthDate DateTime?
  phone     String?
  ranking   Int?
  category  String? // ex: "SUB-18", "ADULTO", "SENIOR"
  gender    String? // MALE, FEMALE, OTHER
  clubId    String? // clube que cadastrou (visão completa)
  isPublic  Boolean   @default(true) // se aparece em busca global

  // Campos extras para importação em massa
  cpf       String?   @unique
  entity    String?   // entidade esportiva
  fatherName String?
  fatherCpf  String?
  motherName String?
  motherCpf  String?

  // Documentos (upload futuro — campos desativados por enquanto)
  docRgUrl            String?
  docMedicalCertUrl   String? // atestado médico

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  matchesAsP1       Match[]           @relation("MatchPlayer1")
  matchesAsP2       Match[]           @relation("MatchPlayer2")
  tournamentEntries TournamentEntry[]

  @@index([name])
  @@index([clubId])
  @@index([cpf])
  @@map("athlete_profiles")
}

// ============================================================
// FASE 3: Torneios e Competições
// ============================================================

/// Torneio criado por um clube.
model Tournament {
  id               String           @id @default(cuid())
  clubId           String
  name             String
  description      String?
  startDate        DateTime?
  endDate          DateTime?
  format           TournamentFormat @default(SINGLE_ELIMINATION)
  sportType        String           @default("TENNIS")
  courtType        String? // CLAY, HARD, GRASS
  status           TournamentStatus @default(DRAFT)
  maxPlayers       Int?
  rules            String? // JSON com regras específicas (matchFormat, setsToWin, etc)
  registrationType          String  @default("INVITE_ONLY") // OPEN, INVITE_ONLY, CLUB_ONLY
  isInternal                Boolean @default(false) // true = torneio de treino (COACH)
  isOpenToExternalAthletes  Boolean @default(false) // true = aceita atletas de outros clubes
  createdAt                 DateTime @default(now())
  updatedAt        DateTime         @updatedAt

  club       Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  categories TournamentCategory[]
  entries    TournamentEntry[]
  matches    Match[]               @relation("TournamentMatches")
  organizers TournamentOrganizer[]

  @@index([clubId])
  @@index([status])
  @@map("tournaments")
}

/// Categoria dentro de um torneio (ex: Masculino Sub-18, Feminino Adulto).
model TournamentCategory {
  id           String  @id @default(cuid())
  tournamentId String
  name         String // ex: "Masculino Adulto", "Feminino Sub-18"
  gender       String? // MALE, FEMALE, MIXED
  ageGroup     String? // SUB-14, SUB-18, ADULT, SENIOR
  maxPlayers   Int?
  bracketType  String  @default("SINGLE_ELIMINATION")

  tournament Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  entries    TournamentEntry[]
  matches    Match[]           @relation("CategoryMatches")

  @@unique([tournamentId, name])
  @@map("tournament_categories")
}

/// Inscrição de um atleta em uma categoria de torneio.
model TournamentEntry {
  id           String                @id @default(cuid())
  tournamentId String
  categoryId   String?
  athleteId    String
  seed         Int? // Cabeça de chave (1, 2, 3...)
  status       TournamentEntryStatus @default(REGISTERED)

  tournament Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category   TournamentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  athlete    AthleteProfile      @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tournamentId, categoryId, athleteId])
  @@index([tournamentId])
  @@map("tournament_entries")
}

/// Organizadores de torneio (relação N:N entre User e Tournament).
model TournamentOrganizer {
  id           String        @id @default(cuid())
  userId       String
  tournamentId String
  role         OrganizerRole @default(ORGANIZER)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
  @@map("tournament_organizers")
}

// ============================================================
// Match (expandido com referências a Club, Athletes e Tournament)
// ============================================================

model Match {
  id        String  @id @default(cuid())
  sportType String
  format    String
  nickname  String?
  courtType String?

  // === Migração: campos legados mantidos para retrocompatibilidade ===
  apontadorEmail String? // legado → substituído por scorerId (marcador comunitário)
  playerP1       String // legado → nome string
  playerP2       String // legado → nome string
  playersEmails  String[]

  // === Novos campos de identidade ===
  createdByUserId String? // User que criou a partida
  clubId          String? // Clube dono (null = partida pública/avulsa)
  homeClubId      String? // Clube do atleta 1 (derivado de player1.clubId)
  awayClubId      String? // Clube do atleta 2 (derivado de player2.clubId)
  player1Id       String? // AthleteProfile do jogador 1
  player2Id       String? // AthleteProfile do jogador 2
  tournamentId    String? // Torneio vinculado (null = partida avulsa)
  categoryId      String? // Categoria do torneio
  roundNumber     Int? // Rodada no torneio (1 = final, 2 = semifinal, etc)
  bracketPosition Int? // Posição no chaveamento
  scheduledAt     DateTime? // Data/hora agendada da partida
  venueId         String? // Local da partida (diretório central)

  // === Visibilidade ===
  visibility          MatchVisibility @default(PLAYERS_ONLY)
  openForAnnotation   Boolean         @default(false) // Permite qualquer autenticado anotar

  status    MatchStatus @default(NOT_STARTED)
  score     String?
  winner    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  completedSets String? // JSON string
  matchState    String? // JSON string — estado completo do TennisScoring

  // === Relações ===
  createdBy  User?               @relation("MatchCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  venue      Venue?              @relation(fields: [venueId], references: [id], onDelete: SetNull)
  club       Club?               @relation(fields: [clubId], references: [id], onDelete: SetNull)
  homeClub   Club?               @relation("MatchHomeClub", fields: [homeClubId], references: [id], onDelete: SetNull)
  awayClub   Club?               @relation("MatchAwayClub", fields: [awayClubId], references: [id], onDelete: SetNull)
  player1    AthleteProfile?     @relation("MatchPlayer1", fields: [player1Id], references: [id], onDelete: SetNull)
  player2    AthleteProfile?     @relation("MatchPlayer2", fields: [player2Id], references: [id], onDelete: SetNull)
  tournament Tournament?         @relation("TournamentMatches", fields: [tournamentId], references: [id], onDelete: SetNull)
  category   TournamentCategory? @relation("CategoryMatches", fields: [categoryId], references: [id], onDelete: SetNull)
  annotationSessions  MatchAnnotationSession[]
  comparisons         MatchAnnotationComparison[]
  dashboardShares     MatchDashboardShare[]

  @@index([clubId])
  @@index([status])
  @@index([tournamentId])
  @@index([createdByUserId])
  @@index([venueId])
  @@map("matches")
}

/// Diretório central de locais de partida — acessível a qualquer usuário autenticado.
model Venue {
  id              String   @id @default(cuid())
  name            String
  address         String?
  city            String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  createdBy User?   @relation("VenueCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  matches   Match[]

  @@index([name])
  @@map("venues")
}

// ============================================================
// FASE 4: Sessões de Anotação (evita split-brain placar)
// ============================================================

/// Sessão de anotação de uma partida. Múltiplas sessões podem estar ativas por vez (multi-anotador).
/// Cada anotador tem sua própria sessão independente, vinculada ao matchId.
model MatchAnnotationSession {
  id                   String                  @id @default(cuid())
  matchId              String
  annotatorUserId      String    // Quem está anotando
  startedAt            DateTime  @default(now())
  endedAt              DateTime? // null = sessão ativa
  matchStateSnapshot   String?   // JSON — snapshot do matchState no início da sessão
  finalStateSnapshot   String?   // JSON — snapshot ao encerrar (para comparativo)
  isActive             Boolean   @default(true)
  status               AnnotationSessionStatus @default(IN_PROGRESS)
  createdAt            DateTime  @default(now())

  match     Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  annotator User   @relation("AnnotationSessions", fields: [annotatorUserId], references: [id], onDelete: Cascade)

  endorsements AnnotationEndorsement[]

  @@index([matchId])
  @@index([annotatorUserId])
  @@index([isActive])
  @@map("match_annotation_sessions")
}

/// Endosso de uma sessão de anotação (validação por participante/coach).
model AnnotationEndorsement {
  id               String   @id @default(cuid())
  sessionId        String
  endorsedByUserId String   // Quem endossou (jogador, coach)
  endorsedAt       DateTime @default(now())

  session    MatchAnnotationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  endorsedBy User                   @relation("Endorsements", fields: [endorsedByUserId], references: [id], onDelete: Cascade)

  @@unique([sessionId, endorsedByUserId])
  @@map("annotation_endorsements")
}

// ============================================================
// FASE COMMUNITY: Comparativo de anotações e compartilhamento
// ============================================================

/// Comparativo gerado a partir de múltiplas sessões de anotação finalizadas.
/// Consolida ponto-a-ponto com indicação de consenso vs divergência por anotador.
model MatchAnnotationComparison {
  id        String   @id @default(cuid())
  matchId   String
  payload   Json     // { points: [{ index, consensus, sessions: { userId: pointData } }] }
  status    String   @default("PENDING") // PENDING | PUBLISHED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("match_annotation_comparisons")
}

/// Compartilhamento de resultado de partida com stakeholders (clubes e atletas).
/// Criado automaticamente ao finalizar uma partida pública.
model MatchDashboardShare {
  id            String               @id @default(cuid())
  matchId       String
  targetUserId  String?  // null = destinado a clube
  targetClubId  String?  // null = destinado a usuário individual
  shareType     DashboardShareType   @default(ANNOTATION)
  status        DashboardShareStatus @default(PENDING)
  notifiedAt    DateTime             @default(now())
  respondedAt   DateTime?

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([targetUserId])
  @@index([targetClubId])
  @@index([status])
  @@map("match_dashboard_shares")
}

