{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    },
    { "src": "frontend/api/matches.js", "use": "@vercel/node" },
    { "src": "frontend/api/clubs.js", "use": "@vercel/node" },
    { "src": "frontend/api/auth.js", "use": "@vercel/node" },
    { "src": "frontend/api/athletes.js", "use": "@vercel/node" },
    { "src": "frontend/api/tournaments.js", "use": "@vercel/node" },
    { "src": "frontend/api/admin.js", "use": "@vercel/node" },
    { "src": "frontend/api/webhooks.js", "use": "@vercel/node" },
    { "src": "frontend/api/cron.js", "use": "@vercel/node" },
    { "src": "frontend/api/health.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/matches[^?#]*", "dest": "/frontend/api/matches.js" },
    { "src": "/api/clubs[^?#]*", "dest": "/frontend/api/clubs.js" },
    { "src": "/api/auth[^?#]*", "dest": "/frontend/api/auth.js" },
    { "src": "/api/athletes[^?#]*", "dest": "/frontend/api/athletes.js" },
    { "src": "/api/tournaments[^?#]*", "dest": "/frontend/api/tournaments.js" },
    { "src": "/api/admin[^?#]*", "dest": "/frontend/api/admin.js" },
    { "src": "/api/webhooks[^?#]*", "dest": "/frontend/api/webhooks.js" },
    { "src": "/api/cron[^?#]*", "dest": "/frontend/api/cron.js" },
    { "src": "/api/health", "dest": "/frontend/api/health.js" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}
